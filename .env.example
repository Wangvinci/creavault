# Creavault environment variables
# Copy this file to .env.local and fill in real values.

# ─── Wallet Connect ─────────────────────────────────────────
# Get a project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WC_PROJECT_ID=

# ─── IPFS / Pinata (optional) ──────────────────────────────
# Without this, uploads compute a real CID locally but don't pin remotely.
# Get a JWT at https://app.pinata.cloud/developers/api-keys
NEXT_PUBLIC_PINATA_JWT=
NEXT_PUBLIC_IPFS_GATEWAY=https://w3s.link/ipfs

# ─── Session secret (SIWE auth) ────────────────────────────
# 32+ character random string. Generate: openssl rand -hex 32
SESSION_SECRET=

# ─── RPC (optional overrides) ──────────────────────────────
# Defaults to public endpoints. For production use Alchemy / Infura.
# NEXT_PUBLIC_BASE_RPC=https://mainnet.base.org
# NEXT_PUBLIC_BASE_SEPOLIA_RPC=https://sepolia.base.org

# ─── Contract addresses (filled after deploy) ──────────────
# NEXT_PUBLIC_REGISTRY_BASE=0x...
# NEXT_PUBLIC_RECEIPTS_BASE=0x...
# NEXT_PUBLIC_REGISTRY_BASE_SEPOLIA=0x...
# NEXT_PUBLIC_RECEIPTS_BASE_SEPOLIA=0x...
